{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genkistuff.com/schemas/card-material-profile.schema.json",
  "title": "GenkiStuff Card Material Profile",
  "type": "object",
  "required": ["schemaVersion", "card", "classification", "assets", "renderer", "provenance"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "card": {
      "type": "object",
      "required": ["id", "game", "language"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "game": { "const": "one-piece-card-game" },
        "set": { "type": "string" },
        "rarity": { "type": "string" },
        "language": { "enum": ["EN", "JP", "other"] },
        "printVariant": { "type": "string" }
      },
      "additionalProperties": false
    },
    "classification": {
      "type": "object",
      "required": ["family", "confidence"],
      "properties": {
        "family": {
          "enum": [
            "rare-holo-standard",
            "sr-foil-basic",
            "sr-textured",
            "alt-art-coated",
            "alt-art-textured",
            "manga-prismatic-panel",
            "manga-gold-metallic",
            "sp-gold-ornamental",
            "sp-manga-scene",
            "sp-color-field",
            "leader-parallel-textured",
            "treasure-rare",
            "unknown"
          ]
        },
        "confidence": {
          "enum": ["hypothesis", "photo-validated", "capture-validated", "production-validated"]
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "assets": {
      "type": "object",
      "required": ["albedo"],
      "properties": {
        "albedo": { "$ref": "#/$defs/asset" },
        "foilMask": { "$ref": "#/$defs/asset" },
        "metallicMask": { "$ref": "#/$defs/asset" },
        "glossMask": { "$ref": "#/$defs/asset" },
        "textureMask": { "$ref": "#/$defs/asset" },
        "suppressionMask": { "$ref": "#/$defs/asset" },
        "normalMap": { "$ref": "#/$defs/asset" },
        "directionMap": { "$ref": "#/$defs/asset" },
        "regionMask": { "$ref": "#/$defs/asset" },
        "cardBack": { "$ref": "#/$defs/asset" },
        "gltf": { "$ref": "#/$defs/asset" }
      },
      "additionalProperties": false
    },
    "renderer": {
      "type": "object",
      "required": ["cssPreset", "qualityTier"],
      "properties": {
        "cssPreset": { "type": "string" },
        "webglPreset": { "type": "string" },
        "qualityTier": { "enum": ["grid", "detail", "hero", "research"] },
        "foilStrength": { "type": "number", "minimum": 0, "maximum": 2 },
        "metallicStrength": { "type": "number", "minimum": 0, "maximum": 2 },
        "glossStrength": { "type": "number", "minimum": 0, "maximum": 2 },
        "textureStrength": { "type": "number", "minimum": 0, "maximum": 2 },
        "roughness": { "type": "number", "minimum": 0, "maximum": 1 },
        "clearcoat": { "type": "number", "minimum": 0, "maximum": 1 },
        "clearcoatRoughness": { "type": "number", "minimum": 0, "maximum": 1 },
        "iridescence": { "type": "number", "minimum": 0, "maximum": 1 },
        "iridescenceIor": { "type": "number", "minimum": 1 },
        "iridescenceThicknessMinNm": { "type": "number", "minimum": 0 },
        "iridescenceThicknessMaxNm": { "type": "number", "minimum": 0 },
        "anisotropy": { "type": "number", "minimum": 0, "maximum": 1 },
        "anisotropyRotationRad": { "type": "number" },
        "maxTiltDeg": { "type": "number", "minimum": 0, "maximum": 30 }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["sourceType", "rights", "reviewStatus"],
      "properties": {
        "sourceType": { "enum": ["controlled-capture", "video-sweep", "licensed-photo", "marketplace-reference", "synthetic"] },
        "rights": { "type": "string" },
        "captureSession": { "type": "string" },
        "sourceUrls": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "reviewStatus": { "enum": ["unreviewed", "needs-revision", "approved"] },
        "reviewer": { "type": "string" },
        "approvedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "metrics": {
      "type": "object",
      "properties": {
        "maskIoU": { "type": "number", "minimum": 0, "maximum": 1 },
        "highlightTrajectoryErrorPx": { "type": "number", "minimum": 0 },
        "hueOrderAgreement": { "type": "number", "minimum": 0, "maximum": 1 },
        "reviewScore": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "asset": {
      "type": "object",
      "required": ["uri"],
      "properties": {
        "uri": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "colorSpace": { "enum": ["srgb", "linear", "normal"] },
        "channel": { "type": "string" },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
