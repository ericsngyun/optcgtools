{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genkistuff.com/schemas/agent-ops/appearance-envelope.schema.json",
  "title": "OPTCG Appearance Envelope",
  "description": "Robust cross-source appearance statistics for one card region (ADR-0002, Lane A). Never a physical BRDF measurement: outputs are labeled observed-appearance-proposal, and normal/displacement proposals derived from public imagery must carry evidence_state 'inferred'.",
  "type": "object",
  "required": [
    "schema_version",
    "bundle_id",
    "card_id",
    "region_id",
    "source_count",
    "contributing_source_ids",
    "brightness",
    "chroma_variance",
    "hue_range",
    "specular_activation_frequency",
    "proposals",
    "robust_method",
    "label",
    "evidence_state",
    "generated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "bundle_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,95}$" },
    "card_id": { "type": "string", "minLength": 2, "maxLength": 64 },
    "region_id": { "type": "string", "minLength": 1 },
    "source_count": { "type": "integer", "minimum": 1 },
    "contributing_source_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,95}$" }
    },
    "brightness": {
      "type": "object",
      "required": ["min", "max", "variance", "median"],
      "properties": {
        "min": { "type": "number" },
        "max": { "type": "number" },
        "variance": { "type": "number", "minimum": 0 },
        "median": { "type": "number" }
      },
      "additionalProperties": false
    },
    "chroma_variance": { "type": "number", "minimum": 0 },
    "hue_range": {
      "type": "object",
      "required": ["min_deg", "max_deg", "dominant_hue_axis_deg"],
      "properties": {
        "min_deg": { "type": "number", "minimum": 0, "maximum": 360 },
        "max_deg": { "type": "number", "minimum": 0, "maximum": 360 },
        "dominant_hue_axis_deg": { "type": "number", "minimum": 0, "maximum": 360 }
      },
      "additionalProperties": false
    },
    "specular_activation_frequency": { "type": "number", "minimum": 0, "maximum": 1 },
    "proposals": {
      "type": "object",
      "required": [
        "metallic",
        "foil",
        "clearcoat",
        "black_ink_suppression",
        "texture_frequency",
        "texture_direction_deg",
        "confidence"
      ],
      "properties": {
        "metallic": { "type": "number", "minimum": 0, "maximum": 1 },
        "foil": { "type": "number", "minimum": 0, "maximum": 1 },
        "clearcoat": { "type": "number", "minimum": 0, "maximum": 1 },
        "black_ink_suppression": { "type": "number", "minimum": 0, "maximum": 1 },
        "texture_frequency": { "type": "number", "minimum": 0 },
        "texture_direction_deg": { "type": "number", "minimum": 0, "maximum": 360 },
        "confidence": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      },
      "additionalProperties": false
    },
    "per_pixel_confidence_map": { "type": "string", "minLength": 1 },
    "robust_method": { "type": "string", "minLength": 1 },
    "outlier_sources_excluded": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,95}$" }
    },
    "label": { "const": "observed-appearance-proposal" },
    "evidence_state": { "enum": ["source-supported", "inferred"] },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
