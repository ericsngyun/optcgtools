{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genkistuff.com/schemas/agent-ops/reference-source-quality.schema.json",
  "title": "OPTCG Reference Source Quality Score and Bundle Tier",
  "description": "Per-source quality scoring and the resulting bundle tier gate (ADR-0002, Lane A). Tier C is never eligible for a profile; tier B requires recorded human review.",
  "type": "object",
  "required": ["source_score", "bundle_tier"],
  "properties": {
    "source_score": { "$ref": "#/$defs/sourceScore" },
    "bundle_tier": { "$ref": "#/$defs/bundleTier" }
  },
  "additionalProperties": false,
  "$defs": {
    "sourceScore": {
      "type": "object",
      "required": [
        "source_id",
        "exact_variant_match",
        "english_confirmation",
        "surface_visibility",
        "angles_score",
        "macro_score",
        "lighting_diversity",
        "resolution_score",
        "compression_penalty",
        "editing_risk_penalty",
        "proxy_risk_penalty",
        "alignment_success",
        "weights",
        "composite_score",
        "tier",
        "tier_rationale",
        "computed_at"
      ],
      "properties": {
        "source_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,95}$" },
        "exact_variant_match": { "type": "number", "minimum": 0, "maximum": 1 },
        "english_confirmation": { "type": "number", "minimum": 0, "maximum": 1 },
        "surface_visibility": { "type": "number", "minimum": 0, "maximum": 1 },
        "angles_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "macro_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "lighting_diversity": { "type": "number", "minimum": 0, "maximum": 1 },
        "resolution_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "compression_penalty": { "type": "number", "minimum": 0, "maximum": 1 },
        "editing_risk_penalty": { "type": "number", "minimum": 0, "maximum": 1 },
        "proxy_risk_penalty": { "type": "number", "minimum": 0, "maximum": 1 },
        "alignment_success": { "type": "number", "minimum": 0, "maximum": 1 },
        "weights": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        },
        "composite_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "tier": { "enum": ["A", "B", "C"] },
        "tier_rationale": { "type": "string", "minLength": 1 },
        "computed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "bundleTier": {
      "type": "object",
      "required": ["bundle_id", "tier", "source_scores", "human_reviewed_tier_b", "eligible_for_profile"],
      "properties": {
        "bundle_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,95}$" },
        "tier": { "enum": ["A", "B", "C"] },
        "source_scores": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sourceScore" }
        },
        "human_reviewed_tier_b": {
          "type": "boolean",
          "description": "Required true whenever tier is 'B'; tier 'C' is never eligible_for_profile."
        },
        "reviewer": { "type": ["string", "null"] },
        "eligible_for_profile": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
