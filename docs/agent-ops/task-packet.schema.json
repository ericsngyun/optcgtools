{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genkistuff.com/schemas/agent-ops/task-packet.schema.json",
  "title": "OPTCG Lab Task Packet",
  "description": "No implementation agent begins substantial work without a validated task packet.",
  "type": "object",
  "required": [
    "task_id",
    "objective",
    "current_state",
    "allowed_paths",
    "forbidden_paths",
    "acceptance_criteria",
    "required_tests",
    "stop_conditions",
    "expected_outputs",
    "reviewer"
  ],
  "properties": {
    "task_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,95}$" },
    "objective": { "type": "string", "minLength": 10 },
    "current_state": {
      "type": "string",
      "description": "What is implemented, validated, or missing before this task starts."
    },
    "inputs": { "type": "array", "items": { "type": "string" } },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "The only paths this agent may modify."
    },
    "forbidden_paths": { "type": "array", "items": { "type": "string" } },
    "required_reading": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "evidence_available": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Authenticated captures, reviewed masks, or public references usable as evidence."
    },
    "acceptance_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "required_tests": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "required_visual_checks": { "type": "array", "items": { "type": "string" } },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Conditions under which the agent stops and reports instead of improvising."
    },
    "expected_outputs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "reviewer": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
